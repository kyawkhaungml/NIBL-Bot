# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Supabase credentials
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Operator WhatsApp number (your personal number in E.164 format)
OPERATOR_WHATSAPP=whatsapp:+1XXXXXXXXXX
# Optional second admin (e.g. a dasher) — leave blank to disable
OPERATOR_WHATSAPP_2=whatsapp:+1XXXXXXXXXX

# Server
PORT=3000

# Public URL for webhook validation (ngrok URL locally, Railway URL in production)
PUBLIC_URL=https://your-railway-url.up.railway.app

# Referral link base URL
BASE_URL=https://nibl.app

# Current deal text (shown when customer texts DEAL)
CURRENT_DEAL=This week only: order any sushi and we'll add a free matcha latte 🍵 Just send your screenshot!

SKIP_TWILIO_VALIDATION=false
